{
  "name": "site-vitrine-offer-automation",
  "version": "0.1.0",
  "description": "Automacao inicial para ingestao, validacao e normalizacao de ofertas do Site Vitrine.",
  "private": true,
  "type": "module",
  "scripts": {
    "collect:shopee": "node collectors/shopee/collect-shopee-offers.js",
    "ingest": "node ingest/google-sheets-ingest.js",
    "ingest:sheets": "node ingest/google-sheets-ingest.js",
