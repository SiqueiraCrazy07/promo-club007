    "validate": "node validators/offer-validator.js",
    "normalize": "node normalizers/offer-normalizer.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "googleapis": "^144.0.0"
  }
